includes:
    - vendor/larastan/larastan/extension.neon
    - phpstan-baseline.neon

parameters:
    paths:
        - app/

    # Level 0 (en gevşek) – 10 (en strict). 5 Laravel için pragmatik başlangıç.
    level: 5

    # Eloquent/Carbon cast'leri PHPDoc generic'lerle çakışıyor; type narrowing
    # uyarılarını sustur. Gerçek tip hatalarını yine yakalar.
    treatPhpDocTypesAsCertain: false
