APP_NAME="Koğ Suit Otel"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://kogsuitotel.test

APP_LOCALE=tr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=tr_TR

# Admin user — ilk migrate+seed sırasında oluşturulur.
# ⚠️ ADMIN_PASSWORD ZORUNLU (lokal + prod). Seeder placeholder reddeder.
#    Güçlü password üret:
#      php -r "echo base64_encode(random_bytes(24)) . PHP_EOL;"
#    veya:
#      openssl rand -base64 32
#    Üretilen değeri .env'de ADMIN_PASSWORD'a yapıştır. Repo'ya commit edilmez (.env gitignore).
ADMIN_NAME="Otel Yönetici"
ADMIN_EMAIL=admin@kogsuitotel.com
ADMIN_PASSWORD=

# SEO — Doğrulama meta tag'leri (Google Search Console + Bing Webmaster)
# Cloudflare-GSC entegrasyonu kullanılırsa TXT record otomatik eklendiği için bu env boş kalabilir.
SEO_GOOGLE_VERIFICATION=
SEO_BING_VERIFICATION=
SEO_YANDEX_VERIFICATION=

# Google Analytics 4 — boş bırakılırsa GA4 tag ve cookie banner gizlenir.
# KVKK m.5 açık rıza için Consent Mode v2 default deny aktiftir; kullanıcı cookie
# banner'dan "Kabul Et" tıklayana kadar GA4 çerez yerleştirmez.
SEO_GA4_ID=

# SEO — Yerel koordinatlar (Varto merkez)
SEO_GEO_LAT=38.9211
SEO_GEO_LNG=41.4544

# SEO — Default Open Graph image (sosyal medya paylaşımında görünen kart)
# Demo: Unsplash kaynaklı geçici görsel. Sahibin gerçek otel foto'su geldiğinde
# `/images/og-default.jpg` (1200×630) olarak public/images altına konur, env güncellenir.
SEO_DEFAULT_OG_IMAGE=/images/demo/og/og-default.jpg

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ⚠️ PROD .env'sinde MUTLAKA aşağıdaki satırlar değişmeli (KVKK/güvenlik):
#   SESSION_SECURE_COOKIE=true        # HTTPS dışında cookie göndermesin
#   SESSION_ENCRYPT=true              # session payload şifrele (form old() PII)
#   SESSION_LIFETIME=30               # admin idle timeout (120 → 30 dk)
#   LOG_LEVEL=warning                 # prod'da debug PII trace'lerini engelle
#   APP_DEBUG=false                   # prod'da exception trace açık olmasın

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail bildirimleri proje kararıyla kaldırıldı (havale+WhatsApp akışı yeterli).
# Laravel core internal mesajları için minimal config.
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@kogsuitotel.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Cloudflare R2 — Spatie Laravel Backup hedefi (S3-uyumlu, 10GB ücretsiz, egress free)
# Dashboard → R2 → Manage API Tokens → Create (Admin Read & Write, sadece kogsuit-backup bucket)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=kogsuit-backup
R2_ENDPOINT=

# Backup arşiv şifreleme parolası (AES-256). Boşsa şifresiz zip oluşturulur (önerilmez).
# Üretmek için: php -r "echo base64_encode(random_bytes(32)) . PHP_EOL;"
# UNUTMAYIN: Bu password'u Bitwarden gibi yere kaydedin — restore için lazım olur.
BACKUP_ARCHIVE_PASSWORD=

VITE_APP_NAME="${APP_NAME}"
